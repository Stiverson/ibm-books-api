{
  "compilerOptions": {

    "rootDir": "./src",
    "outDir": "./dist",

    
    "target": "ES2022",                             
    "module": "commonjs",                          
    "lib": ["ES2022"],
    "esModuleInterop": true,                       
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,                      

   
    "strict": true,
    "noImplicitAny": true,
    "skipLibCheck": true,                          
    "noUncheckedIndexedAccess": true,              
    
    
    "sourceMap": true,
    "declaration": true,
    "declarationMap": true,
    

    "moduleDetection": "force"
  },
  "include": ["src/**/*"],                         
  "exclude": ["node_modules", "dist", "**/*.spec.ts"]
}